# ==================================================
# SUPER BOT DE VENTAS WHATSAPP - Variables de Entorno
# ==================================================
# Copia este archivo como .env y completa los valores

# --------------------------------------------------
# WhatsApp Business API (Meta)
# --------------------------------------------------
# Token de acceso de tu App de Meta (ya lo tenés configurado)
WHATSAPP_TOKEN=tu_token_de_meta_aqui

# ID del número de teléfono de WhatsApp Business
# Lo encontrás en Meta for Developers > Tu App > WhatsApp > Configuración de API
WHATSAPP_PHONE_ID=tu_phone_number_id

# Token de verificación del webhook (lo inventás vos, puede ser cualquier string)
WHATSAPP_VERIFY_TOKEN=mi_token_super_secreto_2024

# ID de la cuenta de WhatsApp Business (opcional)
WHATSAPP_BUSINESS_ID=tu_business_account_id

# Versión de la API (no cambiar a menos que Meta actualice)
WHATSAPP_API_VERSION=v19.0

# --------------------------------------------------
# Base de Datos PostgreSQL (Railway)
# --------------------------------------------------
# Formato: postgresql://usuario:password@host:puerto/nombre_db
# Este dato lo obtenés en Railway > Tu Proyecto > PostgreSQL > Connect
DATABASE_URL=postgresql://postgres:password@roundhouse.proxy.rlwy.net:12345/railway

# --------------------------------------------------
# OpenAI (para las respuestas inteligentes del bot)
# --------------------------------------------------
OPENAI_API_KEY=sk-tu_api_key_de_openai_aqui

# Modelo a usar: gpt-4o-mini (más barato) o gpt-4o (mejor calidad)
OPENAI_MODEL=gpt-4o-mini

# Máximo de tokens por respuesta (500 es suficiente para WhatsApp)
OPENAI_MAX_TOKENS=500

# --------------------------------------------------
# Configuración del Bot
# --------------------------------------------------
# Nombre del bot (parecerá una persona real con este nombre)
BOT_NAME=Sofia

# Nombre de tu negocio
BUSINESS_NAME=Mi Negocio

# Personalidad del bot (se usa en el prompt de la IA)
BOT_PERSONALITY=amigable, persuasiva, profesional, empática

# --------------------------------------------------
# Horarios de Atención (formato 24 horas)
# --------------------------------------------------
# Hora de inicio de atención (ej: 8 = 8:00 AM)
HORARIO_INICIO=8

# Hora de fin de atención (ej: 21 = 9:00 PM)
HORARIO_FIN=21

# --------------------------------------------------
# Servidor
# --------------------------------------------------
PORT=3000
NODE_ENV=production

# Nivel de logs: debug, info, warn, error
LOG_LEVEL=info
